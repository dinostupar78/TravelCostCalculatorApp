<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="#F3F5F8" />
            <stroke
                android:width="1dp"
                android:color="#D5DCE5" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item
        android:width="20dp"
        android:height="20dp"
        android:gravity="end|center_vertical"
        android:right="12dp"
        android:drawable="@drawable/ic_spinner_chevron" />

</layer-list>
